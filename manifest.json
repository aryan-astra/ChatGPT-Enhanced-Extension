{
  "manifest_version": 3,
  "name": "ChatGPT Enhanced",
  "version": "3.5.0",
  "description": "Fixes typing lag with DOM virtualization and adds bulk sidebar management (select, archive, delete).",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/chatgpt-enhanced-48_logo.png",
    "48": "assets/chatgpt-enhanced-48_logo.png",
    "128": "assets/chatgpt-enhanced-128_logo.png"
  },
  "action": {
    "default_title": "ChatGPT Enhanced",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/chatgpt-enhanced-48_logo.png",
      "48": "assets/chatgpt-enhanced-48_logo.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
