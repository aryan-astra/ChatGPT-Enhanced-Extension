{
  "manifest_version": 3,
  "name": "Modus",
  "version": "3.5.1",
  "description": "Fixes typing lag with DOM virtualization and adds bulk sidebar management (select, archive, delete).",
  "permissions": [
    "activeTab",
    "scripting",
    "webRequest",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://*.chatgpt.com/*",
    "*://chat.openai.com/*",
    "*://*.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "assets/modus-16x16.png",
    "32": "assets/modus-32x32.png",
    "48": "assets/modus-48x48.png",
    "128": "assets/modus-128x128.png",
    "512": "assets/modus-512x512.png"
  },
  "action": {
    "default_title": "Modus",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "assets/modus-16x16.png",
      "32": "assets/modus-32x32.png",
      "48": "assets/modus-48x48.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://*.chatgpt.com/*",
        "*://chat.openai.com/*",
        "*://*.openai.com/*"
      ],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ]
}
